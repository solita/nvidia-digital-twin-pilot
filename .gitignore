# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Simulation run outputs ────────────────────────────────────────────────────
# Ignore all runtime-generated content in every simulation's 04_current_outputs/
# folder, but preserve the .gitkeep placeholder so the directory is tracked.
simulations/*/04_current_outputs/*
!simulations/*/04_current_outputs/.gitkeep
warehouse_clean.usd

# ── Windows artifacts ─────────────────────────────────────────────────────────
desktop.ini
Thumbs.db

# ── macOS artifacts ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── VS Code / IDE ─────────────────────────────────────────────────────────────
.vscode/settings.json

# ── Isaac Sim / Omniverse cache ───────────────────────────────────────────────
*.ov_cache
.nvidia-omniverse/
isaac-sim-cache/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
fastdds_client_resolved.xml

# ── Data / databases ──────────────────────────────────────────────────────────
*.db
*.db-wal
*.db-shm

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/

# ── ROS 2 build artifacts ────────────────────────────────────────────────────
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

